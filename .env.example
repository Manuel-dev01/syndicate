# Syndicate — environment configuration template.
# Copy to `.env` (gitignored) and fill in. NEVER commit real secrets.
# Nothing in the codebase may hardcode localhost — all hosts come from here (CLAUDE.md §1.5).

# ---- Canton / Ledger ----
# JSON Ledger API base URL (HTTP JSON API service).
LEDGER_JSON_API_URL=http://127.0.0.1:7575
# gRPC Ledger API v2 endpoint (used where the JSON API is insufficient).
LEDGER_GRPC_HOST=127.0.0.1
LEDGER_GRPC_PORT=6865
# Which network: localnet | sandbox | devnet
CANTON_NETWORK=localnet
# DevNet Global Synchronizer connection (filled in for the live deploy, Phase 3).
DEVNET_SYNCHRONIZER_URL=
DEVNET_PARTICIPANT_URL=

# ---- Daml package ----
# DAR package id / name used by codegen and the agent's choice exercises.
DAML_PACKAGE_NAME=syndicate

# ---- Party identifiers (allocated on the ledger; see scripts/allocate-parties.ts) ----
BORROWER_PARTY=
AGENT_BANK_PARTY=
AGENT_COPILOT_PARTY=
LENDER_A_PARTY=
LENDER_B_PARTY=
LENDER_C_PARTY=

# ---- Auth (party-scoped JWTs for the Ledger API) ----
# Shared secret for HS256 dev tokens (LocalNet only). DevNet uses real issuer keys.
LEDGER_JWT_SECRET=
# Per-party tokens, minted by the auth helper. Leave blank to mint at runtime in dev.
BORROWER_TOKEN=
AGENT_BANK_TOKEN=
AGENT_COPILOT_TOKEN=
LENDER_A_TOKEN=
LENDER_B_TOKEN=
LENDER_C_TOKEN=

# ---- Agent service (separate process; its OWN credentials) ----
# Anthropic API key for the Agent-Bank Co-Pilot's reasoning.
ANTHROPIC_API_KEY=
# Reasoning model (claude-opus-4 class per CLAUDE.md §2).
ANTHROPIC_MODEL=claude-opus-4-8
AGENT_SERVICE_PORT=8080

# ---- Frontend (Next.js) ----
# Public base URL the browser uses to reach the JSON API (proxied in prod).
NEXT_PUBLIC_LEDGER_JSON_API_URL=http://127.0.0.1:7575
NEXT_PUBLIC_AGENT_SERVICE_URL=http://127.0.0.1:8080
