# Syndicate — environment configuration template.
# Copy to `.env` (gitignored) and fill in. NEVER commit real secrets.
# Nothing in the codebase may hardcode localhost — all hosts come from here.

# ---- Canton / Ledger (JSON Ledger API v2 — Canton 3.x, /v2/*) ----
# DevNet (shared Seaport validator): https://ledger-api.validator.devnet.sandbox.fivenorth.io
# Local sandbox: http://127.0.0.1:7575
LEDGER_JSON_API_URL=https://ledger-api.validator.devnet.sandbox.fivenorth.io
# Ledger user whose token the seed scripts use; must hold actAs rights over the demo parties.
# On the shared DevNet validator this is the M2M user id (e.g. 6).
LEDGER_APP_USER=6
# Which network: localnet | devnet
CANTON_NETWORK=devnet

# ---- Auth: OIDC client-credentials (shared DevNet validator). If unset, HS256 local dev token. ----
LEDGER_OIDC_TOKEN_URL=https://auth.sandbox.fivenorth.io/application/o/token/
LEDGER_OIDC_CLIENT_ID=validator-devnet-m2m
LEDGER_OIDC_CLIENT_SECRET=
LEDGER_OIDC_AUDIENCE=validator-devnet-m2m
LEDGER_OIDC_SCOPE=daml_ledger_api

# ---- DevNet validator deployment (see docs/ARCHITECTURE.md → DevNet runbook) ----
# Sponsoring Super Validator base URL (the sv. host, not scan.).
SPONSOR_SV_URL=
# Current DevNet migration id — https://sync.global/sv-network/
MIGRATION_ID=
# Splice release image tag to run.
IMAGE_TAG=
# Party hint for the validator's own party (org-function-enumerator).
PARTY_HINT=syndicate-validator-1
# Path to the LF-2 DAR produced by SDK 3.4.x.
DAR_PATH=daml/.daml/dist/syndicatev3-0.3.0.dar

# ---- Daml package ----
DAML_PACKAGE_NAME=syndicatev3
# Main package id of the uploaded DAR (daml damlc inspect-dar --json $DAR_PATH | jq -r .main_package_id).
DAML_PACKAGE_ID=

# ---- Party identifiers (allocated on the ledger; see scripts/allocate-parties.ts) ----
BORROWER_PARTY=
AGENT_BANK_PARTY=
AGENT_COPILOT_PARTY=
LENDER_A_PARTY=
LENDER_B_PARTY=
LENDER_C_PARTY=

# ---- Web REAL-LEDGER mode (server-side; makes /app exercise real Daml choices on Canton) ----
# Strictly opt-in: unset or anything but "real" → the app runs the in-memory sim (safe default).
# Any missing piece or a ledger failure also falls back to the sim, so the deployed demo never breaks.
LEDGER_MODE=                        # set to "real" to read/write the live ledger
# Reuses LEDGER_JSON_API_URL + DAML_PACKAGE_ID above, plus OIDC (LEDGER_OIDC_*, DevNet) or HS256
# (LEDGER_JWT_SECRET + LEDGER_APP_USER, local sandbox). The web app resolves parties from these:
LEDGER_PARTY_BORROWER=
LEDGER_PARTY_AGENTBANK=
LEDGER_PARTY_AGENT=                 # the Co-Pilot's own party (controller of AssessDrawdown)
LEDGER_PARTY_LENDERA=
LEDGER_PARTY_LENDERB=
LEDGER_PARTY_LENDERC=
LEDGER_FACILITY_ID=MER-2031-B

# ---- API guard for the write/LLM routes (/api/settle, /api/copilot) ----
# Always-on: same-origin enforcement + per-IP rate limiting (in-memory, per instance).
# Optional shared secret: when set, these routes require header `x-syndicate-key: <secret>`. Leave
# UNSET for the public demo (the browser has no secret); set it to lock down a private deployment.
APP_WRITE_SECRET=
# Extra allowed browser origins beyond same-origin (comma-separated), e.g. a custom domain.
APP_ALLOWED_ORIGINS=

# ---- Auth (party-scoped JWTs for the Ledger API) ----
# Shared secret for HS256 dev tokens (LocalNet only). DevNet uses real issuer keys.
LEDGER_JWT_SECRET=
# Per-party tokens, minted by the auth helper. Leave blank to mint at runtime in dev.
BORROWER_TOKEN=
AGENT_BANK_TOKEN=
AGENT_COPILOT_TOKEN=
LENDER_A_TOKEN=
LENDER_B_TOKEN=
LENDER_C_TOKEN=

# ---- Agent-Bank Co-Pilot LLM (DeepSeek; OpenAI-compatible API) ----
# Read server-side only (web/app/api/copilot/route.ts). Without a key the co-pilot returns
# scripted reasoning that still computes the real covenant projection — the breach beat works offline.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
AGENT_SERVICE_PORT=8080

# ---- "Live on Canton DevNet" proof panel (web/app/api/devnet/route.ts, server-side only) ----
# Reads the real shared validator's JSON Ledger API v2 to show the current ledger offset + the
# Syndicate contracts on-ledger. If unset, the panel self-hides (previews stay clean).
DEVNET_LEDGER_URL=https://ledger-api.validator.devnet.sandbox.fivenorth.io
DEVNET_OIDC_TOKEN_URL=https://auth.sandbox.fivenorth.io/application/o/token/
DEVNET_OIDC_CLIENT_ID=validator-devnet-m2m
DEVNET_OIDC_CLIENT_SECRET=
DEVNET_OIDC_AUDIENCE=validator-devnet-m2m
DEVNET_OIDC_SCOPE=daml_ledger_api
# The agent-bank party the panel queries active contracts for (hint::fingerprint).
DEVNET_AGENT_PARTY=

# ---- Frontend (Next.js) ----
# Public base URL the browser uses to reach the JSON API (proxied in prod). Template defaults only —
# production/DevNet values come from the environment; nothing hardcodes localhost.
NEXT_PUBLIC_LEDGER_JSON_API_URL=http://127.0.0.1:7575
NEXT_PUBLIC_AGENT_SERVICE_URL=http://127.0.0.1:8080
