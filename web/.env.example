# Syndicate web app — environment template. Copy to `.env.local` (gitignored) for local dev,
# and set these in the Vercel project for the deployment. No secrets are committed.

# ---- Agent-Bank Co-Pilot (DeepSeek; OpenAI-compatible API) ----
# Without a key, the co-pilot returns scripted reasoning (the UI still works end-to-end).
DEEPSEEK_API_KEY=
# Optional overrides:
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
